{
  "name": "virtual-feast-director-v2",
  "version": "2.0.0",
  "description": "NodeCG bundle for displaying Ontime event information on projection screens",
  "homepage": "https://github.com/marcel-mueller-XI/virtual-feast-director_v2",
  "author": "Marcel Müller",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/marcel-mueller-XI/virtual-feast-director_v2.git"
  },
  "keywords": [
    "nodecg-bundle",
    "ontime",
    "event-management",
    "graphics",
    "streaming"
  ],
  "nodecg": {
    "compatibleRange": "^2.0.0",
    "dashboardPanels": [
      {
        "name": "connection",
        "title": "Connection",
        "width": 2,
        "file": "connection.html",
        "headerColor": "#2c3e50"
      },
      {
        "name": "appearance",
        "title": "Appearance",
        "width": 3,
        "file": "appearance.html",
        "headerColor": "#27ae60"
      },
      {
        "name": "data",
        "title": "Data",
        "width": 3,
        "file": "data.html",
        "headerColor": "#e67e22"
      }
    ],
    "graphics": [
      {
        "file": "director.html",
        "width": 1920,
        "height": 1080
      }
    ]
  },
  "scripts": {
    "build": "tsc -b",
    "watch": "tsc -b --watch",
    "clean": "rimraf extension/**/*.js extension/**/*.js.map",
    "dev": "npm run watch",
    "start": "nodecg start",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,js,json,html,css,md}\""
  },
  "dependencies": {
    "nodecg": "^2.2.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@nodecg/types": "^2.2.0",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.7",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
