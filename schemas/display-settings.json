{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "properties": {
    "colors": {
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "default": "#000000",
          "description": "Text color"
        }
      }
    },
    "font": {
      "type": "string",
      "default": "Arial, sans-serif",
      "description": "Font family for all event text"
    },
    "textSize": {
      "type": "object",
      "properties": {
        "current": {
          "type": "number",
          "default": 2.5,
          "minimum": 0.1,
          "maximum": 15,
          "description": "Font size (vw) for the current event title"
        },
        "upcoming": {
          "type": "number",
          "default": 1.7,
          "minimum": 0.1,
          "maximum": 15,
          "description": "Font size (vw) for upcoming event titles"
        }
      }
    },
    "position": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 100,
          "description": "Horizontal position of the container (% from left)"
        },
        "y": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 100,
          "description": "Vertical position of the container (% from top)"
        }
      }
    },
    "alignment": {
      "type": "string",
      "enum": ["left", "right"],
      "default": "left",
      "description": "Text alignment"
    },
    "maxTextWidth": {
      "type": "number",
      "default": 90,
      "minimum": 5,
      "maximum": 100,
      "description": "Maximum rendered width (vw) of a text line before it is truncated with …"
    },
    "currentBold": {
      "type": "boolean",
      "default": true,
      "description": "Whether the current event title is displayed in bold"
    },
    "countVisibleEvents": {
      "type": "number",
      "default": 4,
      "minimum": 1,
      "maximum": 10,
      "description": "Total number of events to display (including current)"
    }
  },
  "additionalProperties": false
}
